{
    "version": 2,
    "builds": [
        {
            "src": "cecp_project/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15MB"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "cecp_project/wsgi.py"
        }
    ],
    "regions": ["bom1"]
}
