# ==============================================================================
# CECP Club Website - Environment Variables
# ==============================================================================
# ⚠️  REQUIRED SETUP: Copy this file to .env and fill in the values below.
#     Every team member must do this before running the project.
#     Ask the team lead for the shared Supabase credentials.
# ==============================================================================

# Django Secret Key
DJANGO_SECRET_KEY=your-super-secret-key-here
DJANGO_DEBUG=True

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ⚠️  REQUIRED — App will NOT start without this!
# Get the exact value from the team lead or Supabase Dashboard > Settings > Database > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres